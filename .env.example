OZ_MODE=table
OZ_INSTANCE_KIND=subprod

# Primary auth is the ServiceNow SDK default login:
# npx --yes @servicenow/sdk@4.8.0 auth --add https://dev000000.service-now.com

# Optional SDK login override for multi-instance work:
# OZ_SN_AUTH_ALIAS=dev

# Optional fallback auth if SDK session auth is unavailable:
# OZ_SN_INSTANCE_URL=https://dev000000.service-now.com
# SN_USER=integration_user
# SN_PASS=replace_me
# SN_BEARER_TOKEN=replace_me

# Optional governance API mode:
# OZ_MODE=governance
# OZ_GOVERNANCE_API_URL=https://dev000000.service-now.com/api/x_operatorzero/operatorzero

# Privacy-forward telemetry defaults to on. Values: true, false.
OZ_TELEMETRY=true

# Optional local storage and query controls:
# OZ_STORAGE_DIR=$HOME/.operatorzero
# OZ_MAX_RECORDS_PER_QUERY=100
